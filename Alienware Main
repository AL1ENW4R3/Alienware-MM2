local function CreateSliderRow(parent, titleText, descText, minVal, maxVal, currentVal, callback)
	local row = Instance.new("Frame", parent)
	row.Size             = UDim2.new(1, 0, 0, 68)
	row.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local titleLbl = Instance.new("TextLabel", row)
	titleLbl.Size                = UDim2.new(0.7, 0, 0, 20)
	titleLbl.Position            = UDim2.new(0, 12, 0, 6)
	titleLbl.BackgroundTransparency = 1
	titleLbl.Text                = titleText
	titleLbl.TextColor3          = Color3.fromRGB(220, 220, 230)
	titleLbl.Font                = Enum.Font.GothamBold
	titleLbl.TextSize            = 13
	titleLbl.TextXAlignment      = Enum.TextXAlignment.Left

	local valueLbl = Instance.new("TextLabel", row)
	valueLbl.Size                = UDim2.new(0, 50, 0, 20)
	valueLbl.Position            = UDim2.new(1, -62, 0, 6)
	valueLbl.BackgroundTransparency = 1
	valueLbl.Text                = tostring(math.floor(currentVal))
	valueLbl.TextColor3          = Color3.fromRGB(100, 200, 140)
	valueLbl.Font = Enum.Font.GothamBold
	valueLbl.TextSize            = 13
	valueLbl.TextXAlignment      = Enum.TextXAlignment.Right

	local descLbl = Instance.new("TextLabel", row)
	descLbl.Size                = UDim2.new(0.8, 0, 0, 16)
	descLbl.Position            = UDim2.new(0, 12, 0, 24)
	descLbl.BackgroundTransparency = 1
	descLbl.Text                = descText
	descLbl.TextColor3          = Color3.fromRGB(140, 140, 150)
	descLbl.Font                = Enum.Font.Gotham
	descLbl.TextSize            = 11
	descLbl.TextXAlignment      = Enum.TextXAlignment.Left

	local trackBG = Instance.new("Frame", row)
	trackBG.Size             = UDim2.new(1, -24, 0, 8)
	trackBG.Position         = UDim2.new(0, 12, 0, 50)
	trackBG.BackgroundColor3 = Color3.fromRGB(50, 50, 56)
	Instance.new("UICorner", trackBG).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame", trackBG)
	fill.Size             = UDim2.new((currentVal - minVal) / (maxVal - minVal), 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(70, 130, 90)
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame", trackBG)
	knob.Size             = UDim2.new(0, 16, 0, 16)
	knob.Position         = UDim2.new((currentVal - minVal) / (maxVal - minVal), -8, 0.5, -8)
	knob.BackgroundColor3 = Color3.fromRGB(210, 210, 220)
	knob.ZIndex           = 3
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local dragging = false

	local function UpdateFromAbsX(absX)
		local trackAbsPos  = trackBG.AbsolutePosition.X
		local trackAbsSize = trackBG.AbsoluteSize.X
		local ratio = math.clamp((absX - trackAbsPos) / trackAbsSize, 0, 1)
		local val   = math.floor(minVal + ratio * (maxVal - minVal))
		fill.Size      = UDim2.new(ratio, 0, 1, 0)
		knob.Position  = UDim2.new(ratio, -8, 0.5, -8)
		valueLbl.Text  = tostring(val)
		callback(val)
	end

	local function StartDrag(input)
		dragging          = true
		main.Draggable    = false
		UpdateFromAbsX(input.Position.X)
	end

	local function StopDrag()
		dragging          = false
		main.Draggable    = true   
	end

	trackBG.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			StartDrag(input)
		end
	end)

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging       = true
			main.Draggable = false
		end
	end)

	TrackConn(UIS.InputEnded:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			StopDrag()
		end
	end))

	TrackConn(UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			UpdateFromAbsX(input.Position.X)
		end
	end))

	return {
		row = row,
		UpdateExternal = function(newVal)
			local ratio = math.clamp((newVal - minVal) / (maxVal - minVal), 0, 1)
			fill.Size = UDim2.new(ratio, 0, 1, 0)
			knob.Position = UDim2.new(ratio, -8, 0.5, -8)
			valueLbl.Text = tostring(math.floor(newVal))
		end
	}
end

