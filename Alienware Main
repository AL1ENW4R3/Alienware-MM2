-- WINDOW COMPRESSION LOGIC
local minimized = false
local slideTweenActive = false

local function SetMinimized(state)
	if slideTweenActive then return end
	slideTweenActive = true
	minimized = state
	
	local targetHeight = minimized and 36 or 340
	local targetText = minimized and "+" or "-"
	
	minimizeBtn.Text = targetText
	
	if minimized then
		contentRoot.Visible = false
		sidebar.Visible     = false
	end
	
	local slideTween = TweenService:Create(
		main,
		TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
		{ Size = UDim2.new(0, 560, 0, targetHeight) }
	)
	
	slideTween:Play()
	slideTween.Completed:Connect(function()
		if not minimized then
			contentRoot.Visible = true
			sidebar.Visible     = true
		end
		slideTweenActive = false
	end)
end

minimizeBtn.MouseButton1Click:Connect(function() SetMinimized(not minimized) end)

local function MobileConnect(btn, callback)
	btn.MouseButton1Click:Connect(callback)
	btn.TouchTap:Connect(function() callback() end)
end

