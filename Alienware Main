	for _, btn in pairs({espBtn, combatBtn, teleportBtn, charBtn, graphicsBtn, miscBtn, settingsBtn}) do
		btn.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
		btn.TextColor3       = Color3.fromRGB(150, 150, 160)
		local stroke = btn:FindFirstChildOfClass("UIStroke")
		if stroke then stroke.Enabled = false end
	end

	if name == "ESP" then
		sectionTitle.Text = "ESP"
		espPage.Visible   = true
		espBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 44)
		espBtn.TextColor3       = Color3.fromRGB(230, 230, 240)
