-- FADE LOGIC
local guiVisible = true
local fadeActive = false
local fadeTargets = {}

local function BuildFadeTargets()
	fadeTargets = {}
	local function Collect(inst)
		if inst:IsA("GuiObject") then
			local bt = inst.BackgroundTransparency
			if bt < 1 then
				table.insert(fadeTargets, { inst = inst, prop = "BackgroundTransparency", opaque = bt })
			end
		end
		if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
			table.insert(fadeTargets, { inst = inst, prop = "TextTransparency",       opaque = inst.TextTransparency })
			table.insert(fadeTargets, { inst = inst, prop = "TextStrokeTransparency", opaque = inst.TextStrokeTransparency })
		end
		if inst:IsA("ImageLabel") or inst:IsA("ImageButton") then
			table.insert(fadeTargets, { inst = inst, prop = "ImageTransparency", opaque = inst.ImageTransparency })
		end
		for _, child in ipairs(inst:GetChildren()) do
			Collect(child)
		end
	end
	Collect(main)
end

local function DoFade(visible)
	if fadeActive then return end
	fadeActive   = true
	guiVisible   = visible
	local dur    = visible and 0.22 or 0.18
	local easeDir = visible and Enum.EasingDirection.Out or Enum.EasingDirection.In

	if visible then
		for _, t in ipairs(fadeTargets) do
			if t.inst and t.inst.Parent then t.inst[t.prop] = 1 end
		end
		main.Visible = true
		local pending = #fadeTargets
		if pending == 0 then fadeActive = false return end
		for _, t in ipairs(fadeTargets) do
			if t.inst and t.inst.Parent then
				local tw = TweenService:Create(t.inst, TweenInfo.new(dur, Enum.EasingStyle.Quad, easeDir), { [t.prop] = t.opaque })
				tw:Play()
				tw.Completed:Connect(function()
					pending = pending - 1
					if pending <= 0 then fadeActive = false end
				end)
			else
				pending = pending - 1
				if pending <= 0 then fadeActive = false end
			end
		end
	else
		local pending = #fadeTargets
		if pending == 0 then main.Visible = false fadeActive = false return end
		for _, t in ipairs(fadeTargets) do
			if t.inst and t.inst.Parent then
				local tw = TweenService:Create(t.inst, TweenInfo.new(dur, Enum.EasingStyle.Quad, easeDir), { [t.prop] = 1 })
				tw:Play()
				tw.Completed:Connect(function()
					pending = pending - 1
					if pending <= 0 then
						main.Visible = false
						fadeActive   = false
					end
				end)
			else
				pending = pending - 1
				if pending <= 0 then main.Visible = false fadeActive = false end
			end
		end
	end
end

