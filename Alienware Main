-- SPECTATE
local currentSpectateTarget = nil

local function SpectatePlayer(targetPlayer, buttonInstance)
	local cam = workspace.CurrentCamera
	if not cam then return end

	if currentSpectateTarget == targetPlayer then
		currentSpectateTarget = nil
		if buttonInstance then buttonInstance.Text = "Spectate" end
		
		local localChar = LocalPlayer.Character
		local localHum  = localChar and localChar:FindFirstChildOfClass("Humanoid")
		cam.CameraSubject = localHum or workspace
		cam.CameraType    = Enum.CameraType.Custom
		return
	end

	local char = targetPlayer and targetPlayer.Character
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	currentSpectateTarget = targetPlayer
	if buttonInstance then buttonInstance.Text = "Unspectate" end

	cam.CameraType    = Enum.CameraType.Follow
	cam.CameraSubject = hum

	local spectateConn
	spectateConn = RunService.RenderStepped:Connect(function()
		if currentSpectateTarget ~= targetPlayer or not Active then
			spectateConn:Disconnect()
			return
		end
		if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
			cam.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		else
			currentSpectateTarget = nil
			if buttonInstance then buttonInstance.Text = "Spectate" end
			local localChar = LocalPlayer.Character
			cam.CameraSubject = localChar and localChar:FindFirstChildOfClass("Humanoid") or workspace
			cam.CameraType    = Enum.CameraType.Custom
			spectateConn:Disconnect()
		end
	end)
	TrackConn(spectateConn)
end

