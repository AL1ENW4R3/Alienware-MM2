		charPage.Visible  = true
		charBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 44)
		charBtn.TextColor3       = Color3.fromRGB(230, 230, 240)
		charBtn:FindFirstChildOfClass("UIStroke").Enabled = true
    elseif name == "Graphics" then
        sectionTitle.Text = "Graphics"
