	task.wait(0.5)
	ScanRoleLabel()
end))

local function GetMurdererV1()
	for _, v in pairs(Players:GetPlayers()) do
		if v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then
			return v, v.Character
		end
	end
end

local function GetSheriffV1()
	for _, v in pairs(Players:GetPlayers()) do
		if v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then
			return v, v.Character
		end
	end
end

local function ResolveRoleFromCache(char)
	for plr, role in pairs(RoleCache) do
		if plr.Character == char then return role end
	end
	return nil
end

local function GetRoleColor(char)
	if RoleESPEnabled then
		local cached = ResolveRoleFromCache(char)
		if cached == "Murderer" then return Color3.fromRGB(204, 0, 0) end
		if cached == "Sheriff"  then return Color3.fromRGB(0, 0, 204) end
		local _, murdererChar = GetMurdererV1()
		local _, sheriffChar  = GetSheriffV1()
		if char == murdererChar then return Color3.fromRGB(204, 0, 0) end
		if char == sheriffChar  then return Color3.fromRGB(0, 0, 204) end
	end
	return Color3.fromRGB(0, 204, 0)
end

