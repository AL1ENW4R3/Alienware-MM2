local function ResolveCursorIcon(id)
	if id == "" then return "" end
	local cleanId = id:gsub("%D", "")
	if cleanId ~= "" then
		return "rbxthumb://type=Asset&id=" .. cleanId .. "&w=150&h=150"
	end
	return ""
end

local function UpdateCursorDisplay()
	local resolved = ResolveCursorIcon(CustomCursorID)
	if resolved ~= "" then
		UIS.MouseIconEnabled  = false
		Mouse.Icon            = "rbxasset://textures/Blank.png"
		CursorOverlay.Image   = resolved
		CursorOverlay.Size    = UDim2.new(0, CustomCursorSize, 0, CustomCursorSize)
		CursorOverlay.Visible = true
	else
		UIS.MouseIconEnabled  = true
		Mouse.Icon            = ""
		CursorOverlay.Visible = false
	end
end

