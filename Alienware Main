-- SPECTATE
local currentSpectateTarget = nil

local function SpectatePlayer(targetPlayer, buttonInstance)
	local cam = workspace.CurrentCamera
	if not cam then return end
	if currentSpectateTarget == targetPlayer then
		currentSpectateTarget = nil
		if buttonInstance then buttonInstance.Text = "Spectate" end
		local localChar = LocalPlayer.Character
		local localHum  = localChar and localChar:FindFirstChildOfClass("Humanoid")
		cam.CameraSubject = localHum or workspace
		cam.CameraType    = Enum.CameraType.Custom
		return
	end
	local char = targetPlayer and targetPlayer.Character
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hum then return end
	currentSpectateTarget = targetPlayer
	if buttonInstance then buttonInstance.Text = "Unspectate" end
	cam.CameraType    = Enum.CameraType.Follow
	cam.CameraSubject = hum
	local spectateConn
	spectateConn = RunService.RenderStepped:Connect(function()
		if currentSpectateTarget ~= targetPlayer or not Active then
			spectateConn:Disconnect()
			return
		end
		if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
			cam.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		else
			currentSpectateTarget = nil
			if buttonInstance then buttonInstance.Text = "Spectate" end
			local localChar = LocalPlayer.Character
			cam.CameraSubject = localChar and localChar:FindFirstChildOfClass("Humanoid") or workspace
			cam.CameraType    = Enum.CameraType.Custom
			spectateConn:Disconnect()
		end
	end)
	TrackConn(spectateConn)
end

-- AIM ASSIST LOGIC
local function GetClosestPlayer()
	local closestPlayer = nil
	local shortestDistance = math.huge
	local localChar = LocalPlayer.Character
	local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
	if not localHRP then return nil end
	
	local localHasGun = false
	if localChar and localChar:FindFirstChild("Gun") then localHasGun = true end
	if LocalPlayer:FindFirstChild("Backpack") and LocalPlayer.Backpack:FindFirstChild("Gun") then localHasGun = true end

	if AimAssistOnlyWithGun and not localHasGun then return nil end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			local hum = player.Character:FindFirstChildOfClass("Humanoid")
			if hrp and hum and hum.Health > 0 then
				local role = GetPlayerRole(player)
				
				if AimAssistOnlyWithGun then
					if role ~= "Murderer" then continue end
				else
					if AimAssistRoleFilter == "Murd/Sheriff" and role == "Innocent" then
						continue
					elseif AimAssistRoleFilter == "Murderer" and role ~= "Murderer" then
						continue
					elseif AimAssistRoleFilter == "Sheriff" and role ~= "Sheriff" then
						continue
					end
				end

				local distance = (hrp.Position - localHRP.Position).Magnitude
				if distance < shortestDistance then
					shortestDistance = distance
					closestPlayer = player
				end
			end
		end
	end
	return closestPlayer
end

