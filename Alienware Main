-- HELPER: RESOLVE RAW ID TO TEXTURE URL
local function ResolveCursorIcon(id)
	if id == "" then return "" end
	local cleanId = id:gsub("%D", "") 
	if cleanId ~= "" then
		return "rbxthumb://type=Asset&id=" .. cleanId .. "&w=150&h=150"
	end
	return ""
end

local function UpdateCursorDisplay()
	local resolved = ResolveCursorIcon(CustomCursorID)
	if resolved ~= "" then
		UIS.MouseIconEnabled = false -- Hard disable core default mouse drawing completely
		Mouse.Icon = "rbxasset://textures/Blank.png" -- Fallback mask engine mouse
		CursorOverlay.Image = resolved
		CursorOverlay.Size = UDim2.new(0, CustomCursorSize, 0, CustomCursorSize)
		CursorOverlay.Visible = true
	else
		UIS.MouseIconEnabled = true -- Restore normal hardware mouse rendering
		Mouse.Icon = "" 
		CursorOverlay.Visible = false
	end
end

TrackConn(RunService.RenderStepped:Connect(function()
	if CursorOverlay.Visible and Active then
		local location = UIS:GetMouseLocation()
		CursorOverlay.Position = UDim2.new(0, location.X, 0, location.Y)
		-- Continuous assertion check to stop Roblox from forcefully drawing hardware pointer lines
		if UIS.MouseIconEnabled then
			UIS.MouseIconEnabled = false
		end
	end
end))

