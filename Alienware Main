end))

local function GetMurdererV1()
	for _, v in pairs(Players:GetPlayers()) do
		if v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then
			return v, v.Character
		end
	end
end

local function GetSheriffV1()
	for _, v in pairs(Players:GetPlayers()) do
		if v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then
			return v, v.Character
		end
	end
end

local function ResolveRoleFromCache(char)
	for plr, role in pairs(RoleCache) do
		if plr.Character == char then return role end
	end
	return nil
end

local function GetRoleColor(char)
	if RoleESPEnabled then
		local cached = ResolveRoleFromCache(char)
		if cached == "Murderer" then return Color3.fromHSV(MurdererHue / 360, 1, 1) end
		if cached == "Sheriff"  then return Color3.fromHSV(SheriffHue / 360, 1, 1) end
		
		local _, murdererChar = GetMurdererV1()
		local _, sheriffChar  = GetSheriffV1()
		
		if char == murdererChar then return Color3.fromHSV(MurdererHue / 360, 1, 1) end
		if char == sheriffChar  then return Color3.fromHSV(SheriffHue / 360, 1, 1) end
	end
	return Color3.fromHSV(InnocentHue / 360, 1, 1)
end

local function GetPlayerRole(player)
	if not player or not player.Character then return "Innocent" end
	local cached = ResolveRoleFromCache(player.Character)
	if cached then return cached end
	local mPlr, _ = GetMurdererV1()
	local sPlr, _ = GetSheriffV1()
	if player == mPlr then return "Murderer" end
	if player == sPlr then return "Sheriff" end
	return "Innocent"
end

